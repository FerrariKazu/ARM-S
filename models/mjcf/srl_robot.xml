<mujoco model="srl_iron_spider">
  <compiler angle="radian" meshdir="../meshes/" autolimits="true"/>

  <option integrator="RK4" timestep="0.002" gravity="0 0 -9.81" impratio="10">
    <flag energy="enable" contact="enable"/>
  </option>

  <default>
    <joint armature="0.01" damping="0.1" limited="true"/>
    <geom contype="1" conaffinity="1" condim="3" density="1000" solref="0.02 1" solimp="0.9 0.95 0.001"/>
    <position kp="100" kv="10" ctrlrange="-3.14 3.14" forcerange="-50 50"/>
    
    <!-- Redesigned Arm Materials -->
    <default class="odd_segment">
      <geom type="capsule" size="0.018 0.04" rgba="0.2 0.25 0.3 1" contype="2" conaffinity="1"/>
    </default>
    <default class="even_segment">
      <geom type="capsule" size="0.018 0.04" rgba="0.05 0.7 0.9 0.9" contype="2" conaffinity="1"/>
    </default>
    <default class="claw">
      <geom type="capsule" size="0.008 0.02" rgba="0.9 0.4 0.1 1"/>
    </default>
    <!-- Human skin tone/style -->
    <default class="human">
      <geom contype="0" conaffinity="0" rgba="0.62 0.52 0.42 1"/>
    </default>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="300" height="300" mark="edge" markrgb=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
  </asset>

  <worldbody>
    <!-- LIGHTING — cinematic multi-light setup -->
    <!-- Key light — front top, warm -->
    <light name="key_light" pos="1 -2 3" 
           dir="-0.3 0.5 -0.8"
           diffuse="0.6 0.65 0.7" specular="0.3 0.3 0.4"
           castshadow="false"/>
    <!-- Fill light — left side, cool cyan tint -->
    <light name="fill_light" pos="-2 0 2"
           dir="0.6 0 -0.5"
           diffuse="0.05 0.2 0.35" specular="0.1 0.1 0.2"
           castshadow="false"/>
    <!-- Rim light — back, purple tint -->
    <light name="rim_light" pos="0 2 1.5"
           dir="0 -0.7 -0.4"
           diffuse="0.2 0.05 0.3" specular="0.1 0 0.15"
           castshadow="false"/>
    <!-- Under-glow — from below, very subtle cyan -->
    <light name="under_glow" pos="0 -0.5 0.1"
           dir="0 0.2 0.8"
           diffuse="0.02 0.08 0.12" specular="0 0 0"
           castshadow="false"/>

    <!-- ENVIRONMENT — a proper room not just a ground plane -->
    <!-- Dark floor with grid feel -->
    <geom name="floor" type="plane" size="4 4 0.1" 
          rgba="0.05 0.08 0.12 1" condim="3"/>
    
    <!-- Three walls forming a corner behind the figure -->
    <geom name="wall_back" type="box" size="4 0.05 2" 
          pos="0 2.0 1" rgba="0.08 0.1 0.15 1"/>
    <geom name="wall_left" type="box" size="0.05 4 2"
          pos="-2.0 0 1" rgba="0.08 0.1 0.15 1"/>
    
    <!-- Workbench in front of figure -->
    <geom name="workbench" type="box" size="0.6 0.3 0.03"
          pos="0 -0.65 0.75" rgba="0.12 0.15 0.2 1"/>
    <!-- Workbench legs -->
    <geom name="bench_leg1" type="cylinder" size="0.02 0.37"
          pos="-0.55 -0.8 0.38" rgba="0.15 0.15 0.2 1"/>
    <geom name="bench_leg2" type="cylinder" size="0.02 0.37"
          pos="0.55 -0.8 0.38" rgba="0.15 0.15 0.2 1"/>
    <geom name="bench_leg3" type="cylinder" size="0.02 0.37"
          pos="-0.55 -0.3 0.38" rgba="0.15 0.15 0.2 1"/>
    <geom name="bench_leg4" type="cylinder" size="0.02 0.37"
          pos="0.55 -0.3 0.38" rgba="0.15 0.15 0.2 1"/>

    <!-- INTERACTIVE OBJECTS — things the arms can pick up -->
    <!-- Object A: Cyan glowing cube — primary target -->
    <body name="obj_cube" pos="0.18 -0.65 0.82">
      <freejoint name="cube_joint"/>
      <geom type="box" size="0.035 0.035 0.035"
            rgba="0.0 0.85 1.0 1" mass="0.3"
            solimp="0.9 0.95 0.001" solref="0.02 1"/>
      <site name="cube_site" size="0.005"/>
    </body>
    
    <!-- Object B: Orange sphere — secondary target -->
    <body name="obj_sphere" pos="-0.18 -0.65 0.82">
      <freejoint name="sphere_joint"/>
      <geom type="sphere" size="0.04"
            rgba="1.0 0.45 0.1 1" mass="0.2"
            solimp="0.9 0.95 0.001" solref="0.02 1"/>
      <site name="sphere_site" size="0.005"/>
    </body>
    
    <!-- Object C: Purple cylinder — handoff object -->
    <body name="obj_cylinder" pos="0.0 -0.65 0.86">
      <freejoint name="cylinder_joint"/>
      <geom type="cylinder" size="0.025 0.055"
            rgba="0.6 0.1 0.9 1" mass="0.25"
            solimp="0.9 0.95 0.001" solref="0.02 1"/>
      <site name="cylinder_site" size="0.005"/>
    </body>

    <!-- FIXED BASE -->
    <body name="torso_base" pos="0 0 0.9" euler="0 0 0">
      <!-- Human Stand-in -->
      <geom name="human_torso" class="human" type="cylinder" size="0.14 0.25" pos="0 0 0" contype="1" conaffinity="2"/>
      <geom name="human_head" class="human" type="sphere" size="0.1" pos="0 -0.05 0.35" contype="1" conaffinity="2"/>
      <geom name="human_r_upper_arm" class="human" type="capsule" fromto="0.18 0 0.2   0.22 0.05 -0.1" size="0.035" contype="1" conaffinity="2"/>
      <geom name="human_l_upper_arm" class="human" type="capsule" fromto="-0.18 0 0.2  -0.22 0.05 -0.1" size="0.035" contype="1" conaffinity="2"/>

      <!-- Backpack: Slim Titanium Disc (centered on spine, mid-back) -->
      <geom name="backpack_disc" type="cylinder" size="0.08 0.03" 
            pos="-0.15 0 0.15" euler="0 1.5708 0" 
            rgba="0.15 0.15 0.18 1" contype="0" conaffinity="0"/>
      
      <!-- RIGHT ARM: mounts from disc, arcs over right shoulder -->
      <body name="r_shoulder_mount" 
            pos="-0.13 -0.07 0.22" euler="-30 -60 -70">
        <joint name="r_joint1" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
        <geom class="odd_segment" pos="0 0 0.04"/>
        <body name="r_seg2" pos="0 0 0.08">
          <joint name="r_joint2" type="hinge" axis="1 0 0" range="-3.14 3.14"/>
          <geom class="even_segment" pos="0 0 0.04"/>
          <geom type="cylinder" size="0.025 0.005" pos="0 0 0" rgba="0.4 0.4 0.4 1" contype="0" conaffinity="0"/>
          <body name="r_seg3" pos="0 0 0.08">
            <joint name="r_joint3" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
            <geom class="odd_segment" pos="0 0 0.04"/>
            <body name="r_seg4" pos="0 0 0.08">
              <joint name="r_joint4" type="hinge" axis="1 0 0" range="-3.14 3.14"/>
              <geom class="even_segment" pos="0 0 0.04"/>
              <body name="r_seg5" pos="0 0 0.08">
                <joint name="r_joint5" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
                <geom class="odd_segment" pos="0 0 0.04"/>
                <body name="r_seg6" pos="0 0 0.08">
                  <joint name="r_joint6" type="hinge" axis="1 0 0" range="-3.14 3.14"/>
                  <geom class="even_segment" pos="0 0 0.04"/>
                  <body name="r_seg7" pos="0 0 0.08">
                    <joint name="r_joint7" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
                    <geom class="odd_segment" pos="0 0 0.04"/>
                    <body name="r_seg8" pos="0 0 0.08">
                      <joint name="r_joint8" type="hinge" axis="1 0 0" range="-3.14 3.14"/>
                      <geom class="even_segment" pos="0 0 0.04"/>
                      <body name="r_claw_base" pos="0 0 0.04">
                        <!-- Central hub -->
                        <geom type="sphere" size="0.022" rgba="0.15 0.15 0.18 1" contype="0" conaffinity="0"/>
                        
                        <!-- Jaw 1 — forward -->
                        <geom type="capsule" fromto="0 0 0  0.0 0.035 0.038" 
                              size="0.008" rgba="0.85 0.35 0.05 1" contype="0" conaffinity="0"/>
                        <geom type="capsule" fromto="0.0 0.035 0.038  0.0 0.028 0.072"
                              size="0.007" rgba="0.85 0.35 0.05 1" contype="0" conaffinity="0"/>
                              
                        <!-- Jaw 2 — back-right (120 degrees) -->
                        <geom type="capsule" fromto="0 0 0  0.030 -0.018 0.038"
                              size="0.008" rgba="0.85 0.35 0.05 1" contype="0" conaffinity="0"/>
                        <geom type="capsule" fromto="0.030 -0.018 0.038  0.024 -0.014 0.072"
                              size="0.007" rgba="0.85 0.35 0.05 1" contype="0" conaffinity="0"/>
                              
                        <!-- Jaw 3 — back-left (240 degrees) -->
                        <geom type="capsule" fromto="0 0 0  -0.030 -0.018 0.038"
                              size="0.008" rgba="0.85 0.35 0.05 1" contype="0" conaffinity="0"/>
                        <geom type="capsule" fromto="-0.030 -0.018 0.038  -0.024 -0.014 0.072"
                              size="0.007" rgba="0.85 0.35 0.05 1" contype="0" conaffinity="0"/>
                              
                        <!-- Inner glow sphere at claw center -->
                        <geom type="sphere" size="0.011" pos="0 0 0.04" 
                              rgba="0.0 0.85 1.0 0.9" contype="0" conaffinity="0"/>
                              
                        <site name="r_gripper" pos="0 0 0.075" size="0.005"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

      <!-- LEFT ARM: mounts from disc, arcs over left shoulder -->
      <body name="l_shoulder_mount" 
            pos="-0.13 0.07 0.22" euler="-30 60 70">
        <joint name="l_joint1" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
        <geom class="odd_segment" pos="0 0 0.04"/>
        <body name="l_seg2" pos="0 0 0.08">
          <joint name="l_joint2" type="hinge" axis="1 0 0" range="-3.14 3.14"/>
          <geom class="even_segment" pos="0 0 0.04"/>
          <geom type="cylinder" size="0.025 0.005" pos="0 0 0" rgba="0.4 0.4 0.4 1" contype="0" conaffinity="0"/>
          <body name="l_seg3" pos="0 0 0.08">
            <joint name="l_joint3" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
            <geom class="odd_segment" pos="0 0 0.04"/>
            <body name="l_seg4" pos="0 0 0.08">
              <joint name="l_joint4" type="hinge" axis="1 0 0" range="-3.14 3.14"/>
              <geom class="even_segment" pos="0 0 0.04"/>
              <body name="l_seg5" pos="0 0 0.08">
                <joint name="l_joint5" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
                <geom class="odd_segment" pos="0 0 0.04"/>
                <body name="l_seg6" pos="0 0 0.08">
                  <joint name="l_joint6" type="hinge" axis="1 0 0" range="-3.14 3.14"/>
                  <geom class="even_segment" pos="0 0 0.04"/>
                  <body name="l_seg7" pos="0 0 0.08">
                    <joint name="l_joint7" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
                    <geom class="odd_segment" pos="0 0 0.04"/>
                    <body name="l_seg8" pos="0 0 0.08">
                      <joint name="l_joint8" type="hinge" axis="1 0 0" range="-3.14 3.14"/>
                      <geom class="even_segment" pos="0 0 0.04"/>
                      <body name="l_claw_base" pos="0 0 0.04">
                        <!-- Central hub -->
                        <geom type="sphere" size="0.022" rgba="0.15 0.15 0.18 1" contype="0" conaffinity="0"/>
                        
                        <!-- Jaw 1 — forward -->
                        <geom type="capsule" fromto="0 0 0  0.0 0.035 0.038" 
                              size="0.008" rgba="0.85 0.35 0.05 1" contype="0" conaffinity="0"/>
                        <geom type="capsule" fromto="0.0 0.035 0.038  0.0 0.028 0.072"
                              size="0.007" rgba="0.85 0.35 0.05 1" contype="0" conaffinity="0"/>
                              
                        <!-- Jaw 2 — back-right (120 degrees) -->
                        <geom type="capsule" fromto="0 0 0  0.030 -0.018 0.038"
                              size="0.008" rgba="0.85 0.35 0.05 1" contype="0" conaffinity="0"/>
                        <geom type="capsule" fromto="0.030 -0.018 0.038  0.024 -0.014 0.072"
                              size="0.007" rgba="0.85 0.35 0.05 1" contype="0" conaffinity="0"/>
                              
                        <!-- Jaw 3 — back-left (240 degrees) -->
                        <geom type="capsule" fromto="0 0 0  -0.030 -0.018 0.038"
                              size="0.008" rgba="0.85 0.35 0.05 1" contype="0" conaffinity="0"/>
                        <geom type="capsule" fromto="-0.030 -0.018 0.038  -0.024 -0.014 0.072"
                              size="0.007" rgba="0.85 0.35 0.05 1" contype="0" conaffinity="0"/>
                              
                        <!-- Inner glow sphere at claw center -->
                        <geom type="sphere" size="0.011" pos="0 0 0.04" 
                              rgba="0.0 0.85 1.0 0.9" contype="0" conaffinity="0"/>
                              
                        <site name="l_gripper" pos="0 0 0.075" size="0.005"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <equality>
    <weld name="grasp_right" body1="r_claw_base" body2="obj_cube"
          relpose="0 0 -0.06 1 0 0 0"
          active="false" solref="0.01 1" solimp="0.99 0.999 0.0001"/>
    <weld name="grasp_left"  body1="l_claw_base" body2="obj_cube"
          relpose="0 0 -0.06 1 0 0 0"
          active="false" solref="0.01 1" solimp="0.99 0.999 0.0001"/>
    <weld name="grasp_sphere_r" body1="r_claw_base" body2="obj_sphere"
          relpose="0 0 -0.06 1 0 0 0"
          active="false" solref="0.01 1" solimp="0.99 0.999 0.0001"/>
    <weld name="grasp_sphere_l" body1="l_claw_base" body2="obj_sphere"
          relpose="0 0 -0.06 1 0 0 0"
          active="false" solref="0.01 1" solimp="0.99 0.999 0.0001"/>
    <weld name="grasp_cyl_r" body1="r_claw_base" body2="obj_cylinder"
          relpose="0 0 -0.06 1 0 0 0"
          active="false" solref="0.01 1" solimp="0.99 0.999 0.0001"/>
    <weld name="grasp_cyl_l" body1="l_claw_base" body2="obj_cylinder"
          relpose="0 0 -0.06 1 0 0 0"
          active="false" solref="0.01 1" solimp="0.99 0.999 0.0001"/>
  </equality>

  <keyframe>
    <!-- S-Curve Pose: back disc -> up -> forward -> down arc -->
    <!-- qpos includes 3 freejoints (3 * 7 = 21) plus 16 arm joints = 37 -->
    <key name="home"
         qpos="0.18 -0.65 0.82 1 0 0 0
               -0.18 -0.65 0.82 1 0 0 0
               0.0 -0.65 0.86 1 0 0 0
               -1.2  0.5 -0.8  0.4 -0.4  0.3 -0.2  0.1
               -1.2  0.5 -0.8  0.4 -0.4  0.3 -0.2  0.1"/>
  </keyframe>

  <actuator>
    <position name="r_act1" joint="r_joint1"/><position name="r_act2" joint="r_joint2"/>
    <position name="r_act3" joint="r_joint3"/><position name="r_act4" joint="r_joint4"/>
    <position name="r_act5" joint="r_joint5"/><position name="r_act6" joint="r_joint6"/>
    <position name="r_act7" joint="r_joint7"/><position name="r_act8" joint="r_joint8"/>

    <position name="l_act1" joint="l_joint1"/><position name="l_act2" joint="l_joint2"/>
    <position name="l_act3" joint="l_joint3"/><position name="l_act4" joint="l_joint4"/>
    <position name="l_act5" joint="l_joint5"/><position name="l_act6" joint="l_joint6"/>
    <position name="l_act7" joint="l_joint7"/><position name="l_act8" joint="l_joint8"/>
  </actuator>

  <sensor>
    <force name="r_force" site="r_gripper"/>
    <force name="l_force" site="l_gripper"/>
  </sensor>
</mujoco>
